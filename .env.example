# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Society of Catholic Scientists <noreply@catholicscientists.org>
RESEND_REPLY_TO_EMAIL=membership@catholicscientists.org

# ── Turnstile (anti-spam on public forms) ───────────────────────────────────
